{
  "name": "onliner",
  "scripts": {
    "build": "node tools/build.js",
    "watch": "node tools/build.js --watch",
    "serve": "http-server . -a 0.0.0.0 -p 5173 -c-1",
    "serve:https": "http-server . -a 0.0.0.0 -p 5173 -c-1 -S -C .certs/ih35ogb.pem -K .certs/ih35ogb-key.pem",
    "dev": "npm-run-all --parallel watch serve:https",
    "secrets:apply": "node tools/secrets.js"
  },
  "devDependencies": {
    "chokidar-cli": "^3.0.0",
    "http-server": "^14.1.1",
    "npm-run-all": "^4.1.5"
  }
}
